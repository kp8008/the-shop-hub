# Backend API URL. Local: https://localhost:7077/api
# Live (after deploying API on Render): https://your-api.onrender.com/api
# IMPORTANT for Vercel: Set this in Vercel → Project → Settings → Environment Variables
# to your production API URL (e.g. https://the-shop-hub-api.onrender.com/api) then Redeploy.
# Otherwise Forgot Password OTP and all API calls from live site will fail (they would call localhost).
VITE_API_BASE_URL=https://localhost:7077/api

# Google OAuth Client ID for "Sign in with Google" (get from Google Cloud Console)
# Required for pre-filling sign-up form with name and email from Google
VITE_GOOGLE_CLIENT_ID=701994951651-s2ikbs9hm5l5bvckojneoc273ucjil37.apps.googleusercontent.com

# --- Fix "Access blocked / origin_mismatch" on production (e.g. Vercel) ---
# In Google Cloud Console: APIs & Services → Credentials → your OAuth 2.0 Client ID
# 1. Authorized JavaScript origins: add your live URL, e.g. https://the-shop-hub-ecommerce.vercel.app
# 2. Authorized redirect URIs: add the same URL (and https://the-shop-hub-ecommerce.vercel.app/ if needed)
# 3. Set VITE_GOOGLE_CLIENT_ID in Vercel env to the same Client ID. Redeploy after changing.
